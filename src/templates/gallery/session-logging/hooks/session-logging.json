{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "./.github/hooks/scripts/session-audit.sh",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "./.github/hooks/scripts/session-audit.sh",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "./.github/hooks/scripts/session-audit.sh",
        "timeout": 5
      }
    ]
  }
}
